# ─────────────────────────────────────────────────────────────
# Kira — environment variables (copy to .env.local and fill in)
# Per-deployment / per-agency configuration. Phase 0 only needs
# the branding block; Supabase/WhatsApp are wired in later phases.
# ─────────────────────────────────────────────────────────────

# ── Branding / per-client (read in config/site.config.ts) ──
NEXT_PUBLIC_SITE_NAME="Kira"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
NEXT_PUBLIC_DEFAULT_LOCALE="ar"
NEXT_PUBLIC_CURRENCY="MAD"
# Brand colors as HEX. Changing these re-themes the whole site.
NEXT_PUBLIC_PRIMARY_COLOR="#0F3D3E"
NEXT_PUBLIC_SECONDARY_COLOR="#C8A24B"

# ── Supabase ──
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
SUPABASE_SERVICE_ROLE_KEY=""          # server-only — never expose to the browser

# ── WhatsApp Gateway (server-only) — self-hosted Baileys/Evolution ──
WA_GATEWAY_URL=""                     # e.g. https://wa.yourdomain.com
WA_GATEWAY_API_KEY=""                 # shared secret protecting the webhook
AGENCY_WHATSAPP_NUMBER=""             # agency owner's WhatsApp number

# ── Optional ──
RESEND_API_KEY=""
SENTRY_DSN=""
NEXT_PUBLIC_TURNSTILE_SITE_KEY=""
TURNSTILE_SECRET_KEY=""
